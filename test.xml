<mxfile host="app.diagrams.net">
  <diagram name="Restaurant System Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- USERS -->
        <mxCell id="customer" value="Customer" style="rounded=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="80" y="40" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="waiter" value="Waiter" style="rounded=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="240" y="40" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="chef" value="Chef" style="rounded=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="400" y="40" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="admin" value="Admin" style="rounded=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="560" y="40" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- FRONTEND -->
        <mxCell id="frontend1" value="Customer Web App (QR Menu)" style="rounded=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="frontend2" value="Kitchen Dashboard" style="rounded=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="280" y="140" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="frontend3" value="Waiter Dashboard" style="rounded=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="500" y="140" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="frontend4" value="Admin Panel" style="rounded=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="720" y="140" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- BACKEND -->
        <mxCell id="backend" value="Backend API Server (Node.js + Express)" style="rounded=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="300" y="260" width="280" height="70" as="geometry"/>
        </mxCell>

        <!-- REALTIME -->
        <mxCell id="realtime" value="WebSocket Server (Socket.io)&#10;Real-Time Order Updates" style="rounded=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="320" y="360" width="240" height="70" as="geometry"/>
        </mxCell>

        <!-- DATABASE -->
        <mxCell id="database" value="MongoDB Database&#10;Orders | Menu | Users | Payments | Reports" style="rounded=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="330" y="470" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- CONNECTIONS -->
        <mxCell id="e1" edge="1" parent="1" source="customer" target="frontend1"/>
        <mxCell id="e2" edge="1" parent="1" source="waiter" target="frontend3"/>
        <mxCell id="e3" edge="1" parent="1" source="chef" target="frontend2"/>
        <mxCell id="e4" edge="1" parent="1" source="admin" target="frontend4"/>

        <mxCell id="e5" edge="1" parent="1" source="frontend1" target="backend"/>
        <mxCell id="e6" edge="1" parent="1" source="frontend2" target="backend"/>
        <mxCell id="e7" edge="1" parent="1" source="frontend3" target="backend"/>
        <mxCell id="e8" edge="1" parent="1" source="frontend4" target="backend"/>

        <mxCell id="e9" edge="1" parent="1" source="backend" target="realtime"/>
        <mxCell id="e10" edge="1" parent="1" source="realtime" target="database"/>
        <mxCell id="e11" edge="1" parent="1" source="backend" target="database"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>